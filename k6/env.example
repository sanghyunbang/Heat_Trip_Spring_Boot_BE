# Backend EC2 API base URL.
BASE_URL=http://127.0.0.1:8080

# Generic load shape.
VUS=20
DURATION=5m
SLEEP_SECONDS=0.3

# Prefer ACCESS_TOKEN for authenticated tests.
ACCESS_TOKEN=

# Used only when ACCESS_TOKEN is empty and the auth endpoints are available.
TEST_EMAIL=loadtest@example.com
TEST_PASSWORD=Loadtest1234!
TEST_NICKNAME=loadtest
TEST_NAME=k6 load tester

# Explore options.
MAX_PAGE=20
SCROLL_PAGES=2
SEARCH_QUERIES=서울,부산,카페,바다

# Curation options. Non-empty CAT3_FILTER makes /api/curation/recommend skip LLM.
CAT3_FILTER=A02010100,A02020700
USER_LAT=37.5665
USER_LNG=126.9780

# Journey body length. Keep <=255 before the body column is migrated to TEXT.
BODY_CHARS=180

