# Created: 2026-03-18 00:54:24 +09:00
# Copy to .env on the deployment server or local machine.
# Replace every change-me value before running outside local experiments.

# -----------------------------------------------------------------------------
# Spring runtime
# -----------------------------------------------------------------------------
# dev: local development, prod: production/deployment.
SPRING_PROFILES_ACTIVE=dev

# Backend HTTP port and public callback base URL used by OAuth redirect URIs.
SERVER_PORT=8080
APP_BASE_URL=http://10.0.2.2:8080

# -----------------------------------------------------------------------------
# Docker MySQL container initialization
# -----------------------------------------------------------------------------
# These values are consumed by docker-compose.yml -> services.mysql.environment.
# They initialize the MySQL container only when the mysql_data volume is first
# created. Changing them later does not update an existing database volume.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=heat_trip_db
MYSQL_USER=heattrip
MYSQL_PASSWORD=change-me-app-password

# -----------------------------------------------------------------------------
# Spring datasource
# -----------------------------------------------------------------------------
# These values are consumed by the backend app through application-dev/prod.
# Local bootRun usually uses localhost. Docker Compose overrides these app
# datasource values in docker-compose.yml so the app container connects to the
# mysql service name inside the Compose network.
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/heat_trip_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=heattrip
SPRING_DATASOURCE_PASSWORD=change-me-app-password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# HS256 needs at least 32 bytes. Use a long random value.
JWT_SECRET=change-me-jwt-secret-with-at-least-32-bytes
JWT_EXPIRATION=3600000

# -----------------------------------------------------------------------------
# OAuth2 clients
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret
KAKAO_CLIENT_ID=change-me-kakao-client-id
KAKAO_CLIENT_SECRET=change-me-kakao-client-secret
NAVER_CLIENT_ID=change-me-naver-client-id
NAVER_CLIENT_SECRET=change-me-naver-client-secret

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
KAKAO_API_BASE_URL=https://dapi.kakao.com
KAKAO_REST_API_KEY=change-me-kakao-rest-key
TOUR_API_SECRET=change-me-tour-api-key

# -----------------------------------------------------------------------------
# AWS S3 / CloudFront
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=change-me-access-key
AWS_SECRET_ACCESS_KEY=change-me-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=change-me-bucket
AWS_CLOUDFRONT_DOMAIN=https://cdn.example.com

# -----------------------------------------------------------------------------
# LLM recommender
# -----------------------------------------------------------------------------
# Docker internal network example: http://recommender:8000
# Host-local example: http://127.0.0.1:8000
LLM_RECOMMENDER_BASE_URL=http://recommender:8000

# -----------------------------------------------------------------------------
# Public security defaults
# -----------------------------------------------------------------------------
APP_SECURITY_DOCS_PUBLIC=false
APP_SECURITY_ALLOWED_ORIGINS=http://localhost:8080,http://10.0.2.2:8080
APP_SECURITY_RATE_LIMIT_ENABLED=true
APP_SECURITY_RATE_LIMIT_IP_HEADER=X-Forwarded-For
APP_SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
APP_SECURITY_RATE_LIMIT_LOGIN_MAX_REQUESTS=10
APP_SECURITY_RATE_LIMIT_CURATION_MAX_REQUESTS=30
APP_SECURITY_RATE_LIMIT_UPLOAD_MAX_REQUESTS=20
APP_SECURITY_RATE_LIMIT_FEEDBACK_MAX_REQUESTS=30
APP_SECURITY_RATE_LIMIT_SEARCH_MAX_REQUESTS=120

# -----------------------------------------------------------------------------
# Error responses
# -----------------------------------------------------------------------------
SERVER_ERROR_INCLUDE_MESSAGE=never
SERVER_ERROR_INCLUDE_BINDING_ERRORS=never
SERVER_ERROR_INCLUDE_STACKTRACE=never

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOG_LEVEL_ORG_SPRINGFRAMEWORK_HTTP_CONVERTER=INFO
LOG_LEVEL_ORG_SPRINGFRAMEWORK_WEB_MVC_METHOD=INFO

# -----------------------------------------------------------------------------
# Observability integrations
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#backend-alerts
SLACK_BOT_NAME=heat-trip-alert-bot

# -----------------------------------------------------------------------------
# Metrics / local observability stack
# -----------------------------------------------------------------------------
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never
MANAGEMENT_ENDPOINT_PROMETHEUS_ENABLED=true
MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED=true
MANAGEMENT_METRICS_HTTP_HISTOGRAM_ENABLED=true

# docker-compose.observability.yml binds these to 127.0.0.1 by default.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# -----------------------------------------------------------------------------
# OpenAI / Spring AI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
