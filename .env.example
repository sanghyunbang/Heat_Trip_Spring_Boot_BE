# Created: 2026-03-18 00:54:24 +09:00
# Copy to .env on the deployment server or local machine.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=heat_trip_db
MYSQL_USER=heattrip
MYSQL_PASSWORD=change-me-app-password
LLM_RECOMMENDER_BASE_URL=http://recommender:8000

APP_SECURITY_DOCS_PUBLIC=false
APP_SECURITY_ALLOWED_ORIGINS=http://localhost:8080,http://10.0.2.2:8080
APP_SECURITY_RATE_LIMIT_ENABLED=true
APP_SECURITY_RATE_LIMIT_IP_HEADER=X-Forwarded-For
APP_SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
APP_SECURITY_RATE_LIMIT_LOGIN_MAX_REQUESTS=10
APP_SECURITY_RATE_LIMIT_CURATION_MAX_REQUESTS=30
APP_SECURITY_RATE_LIMIT_UPLOAD_MAX_REQUESTS=20
APP_SECURITY_RATE_LIMIT_FEEDBACK_MAX_REQUESTS=30
APP_SECURITY_RATE_LIMIT_SEARCH_MAX_REQUESTS=120

SERVER_ERROR_INCLUDE_MESSAGE=never
SERVER_ERROR_INCLUDE_BINDING_ERRORS=never
SERVER_ERROR_INCLUDE_STACKTRACE=never

LOG_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOG_LEVEL_ORG_SPRINGFRAMEWORK_HTTP_CONVERTER=INFO
LOG_LEVEL_ORG_SPRINGFRAMEWORK_WEB_MVC_METHOD=INFO
