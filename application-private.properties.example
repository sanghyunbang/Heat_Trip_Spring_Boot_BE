# Created: 2026-03-18 00:54:24 +09:00
# Copy to application-private.properties or mount to /config/application-private.properties.
# Replace every placeholder before running in any real environment.

# --- datasource ---
spring.datasource.url=jdbc:mysql://mysql:3306/heat_trip_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
spring.datasource.username=heattrip
spring.datasource.password=change-me-app-password

# --- JWT ---
jwt.secret=change-me-jwt-secret-with-enough-length

# --- OAuth2 ---
spring.security.oauth2.client.registration.google.client-id=change-me
spring.security.oauth2.client.registration.google.client-secret=change-me
spring.security.oauth2.client.registration.google.scope=profile,email

spring.security.oauth2.client.registration.kakao.client-id=change-me
spring.security.oauth2.client.registration.kakao.client-secret=change-me

spring.security.oauth2.client.registration.naver.client-id=change-me
spring.security.oauth2.client.registration.naver.client-secret=change-me

# --- Kakao local API ---
kakao.api.base-url=https://dapi.kakao.com
kakao.api.rest-key=change-me-kakao-rest-key

# --- Tour API ---
TOUR.API.SECRET=change-me-tour-api-key

# --- AWS / S3 ---
cloud.aws.credentials.access-key=change-me-access-key
cloud.aws.credentials.secret-key=change-me-secret-key
cloud.aws.region.static=ap-northeast-2
cloud.aws.s3.bucket=change-me-bucket
cloud.aws.cloudfront.domain=https://cdn.example.com

# --- LLM recommender ---
# Prefer env override `LLM_RECOMMENDER_BASE_URL=http://recommender:8000`
# when backend and recommender run in the same Docker Compose network.
# Use 127.0.0.1 only when the backend process must call a host-local recommender.
llm.recommender.base-url=http://127.0.0.1:8000

# --- Public operation security ---
# Set APP_SECURITY_ALLOWED_ORIGINS in .env for deployment-specific origins.

# --- Observability integrations ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#backend-alerts
SLACK_BOT_NAME=heat-trip-alert-bot

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
